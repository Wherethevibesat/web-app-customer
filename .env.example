NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_BUSINESS_APP_URL=http://localhost:3002

# v2: landing hero background (defaults to public/videos/hero.mp4)
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_HERO_VIDEO_POSTER=

# v2: interactive map (https://account.mapbox.com/)
NEXT_PUBLIC_MAPBOX_TOKEN=

# v2: VIP checkout (publishable key can also come from stripe_settings in Supabase)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend transactional email (server-only)
RESEND_API_KEY=
EMAIL_FROM=WTVA <notifications@wherethevibesat.com>

# AI Concierge (optional). Without a key it falls back to deterministic ranking.
# Key: https://platform.openai.com/api-keys  (pay-as-you-go; gpt-4o-mini is ~$0.001/query)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: point at any OpenAI-compatible provider (e.g. Groq/OpenRouter free tiers)
# OPENAI_BASE_URL=https://api.openai.com/v1
